{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top Cancer Threats: Women (2017-2021)",
    "subtitle": "Percentage of total cases by cancer type",
    "anchor": "middle",
    "fontSize": 16,
    "fontWeight": "bold"
  },
  "width": 500,
  "height": 300,
  "data": {
    "values": [
      {"Cancer_Type": "Breast", "Incidence": 34.1},
      {"Cancer_Type": "Colorectal", "Incidence": 12.7},
      {"Cancer_Type": "Cervical", "Incidence": 8.2},
      {"Cancer_Type": "Lung", "Incidence": 6.0},
      {"Cancer_Type": "Nasopharynx", "Incidence": 2.5},
      {"Cancer_Type": "Others", "Incidence": 36.5}
    ]
  },
  "transform": [
    {
      "calculate": "round((datum.Incidence / 100) * 91131)",
      "as": "Calculated_Cases"
    }
  ],
  "layer": [
    {
      "mark": {"type": "arc", "innerRadius": 80, "stroke": "white", "strokeWidth": 2},
      "encoding": {
        "theta": {
          "field": "Incidence", 
          "type": "quantitative"
        },
        "order": {
          "field": "Incidence",
          "sort": "descending"
        },
        "color": {
          "field": "Cancer_Type",
          "type": "nominal",
          "scale": {
            "domain": ["Breast", "Colorectal", "Cervical", "Lung", "Nasopharynx", "Others"],
            "range": ["#dd3497", "#1f77b4", "#9ecae1", "#ff7f0e", "#8c564b", "#cbd5e1"]
          },
          "legend": {
            "title": null, 
            "orient": "bottom", 
            "direction": "horizontal"
          }
        },
        "tooltip": [
          {"field": "Cancer_Type", "type": "nominal", "title": "Type"},
          {"field": "Incidence", "type": "quantitative", "title": "Percentage (%)", "format": ".1f"},
          {"field": "Calculated_Cases", "type": "quantitative", "title": "Est. Cases", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 24, "fontWeight": "bold", "color": "#dd3497", "text": "91,131"}
    },
    {
      "mark": {"type": "text", "fontSize": 12, "color": "gray", "dy": 22, "text": "Total Cases"}
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "transparent"
  }
}