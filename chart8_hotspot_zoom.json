{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 Districts: Highest Cancer Mortality",
    "subtitle": "Premature cancer mortality rate per 100,000",
    "anchor": "start"
  },
  "width": 350,
  "height": 300,
  "data": {
    "url": "cancer_mortality_district_top10.csv"
  },
  "mark": {"type": "bar", "cornerRadiusEnd": 4},
  "encoding": {
    "y": {
      "field": "District",
      "type": "nominal",
      "sort": "-x",
      "axis": {"title": null, "grid": false}
    },
    "x": {
      "field": "MortalityRate",
      "type": "quantitative",
      "title": "Mortality Rate",
      "axis": {"grid": true}
    },
    "color": {
      "field": "State",
      "type": "nominal",
      "scale": {
        "range": [
          "#1f77b4", 
          "#ff7f0e", 
          "#d62728", 
          "#9467bd", 
          "#8c564b", 
          "#e377c2"
        ]
      },
      "legend": {"orient": "bottom", "title": "State Region"}
    },
    "tooltip": [
      {"field": "District", "type": "nominal"},
      {"field": "State", "type": "nominal"},
      {"field": "MortalityRate", "type": "quantitative", "title": "Mortality Rate", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "background": "transparent"
  }
}