      "legend": {
        "title": "Threat Vector", 
        "orient": "right", 
        "titleFontSize": 12,
        "labelFontSize": 11
      }
    },
    "tooltip": [
      {"field": "Cancer", "type": "nominal", "title": "Cancer Profile"},
      {"field": "Period", "type": "ordinal", "title": "Registry Period"},
      {"field": "ASR", "type": "quantitative", "title": "Incidence ASR", "format": ".1f"}
