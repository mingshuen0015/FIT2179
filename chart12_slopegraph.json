    "color": {
      "field": "Cancer", 
      "type": "nominal",
      "scale": {
        "domain": ["Breast", "Colorectal", "Lung", "Prostate", "Cervical"],
        "range": ["#dd3497", "#1f77b4", "#ff7f0e", "#9467bd", "#9ecae1"]
