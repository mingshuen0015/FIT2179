{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Cancer Mortality Rate by State (2023)",
    "subtitle": "Deaths per 100,000 population",
    "anchor": "start"
  },
  "width": 500,
  "height": 350,
  "data": {
    "url": "malaysia-states.topojson",
    "format": {"type": "topojson", "feature": "states"}
  },
  "transform": [
    {
      "lookup": "properties.Name",
      "from": {
        "data": {"url": "mortality_by_state.csv"},
        "key": "State",
        "fields": ["MortalityRate"]
      }
    }
  ],
  "projection": {"type": "mercator"},
  "mark": {"type": "geoshape", "stroke": "#fff", "strokeWidth": 0.5},
  "encoding": {
    "color": {
      "field": "MortalityRate",
      "type": "quantitative",
      "scale": {"scheme": "reds"},
      "legend": {"title": "Mortality Rate"}
    },
    "tooltip": [
      {"field": "properties.Name", "type": "nominal", "title": "State"},
      {"field": "MortalityRate", "type": "quantitative", "title": "Mortality Rate", "format": ".1f"}
    ]
  },
  "config": {"view": {"stroke": null}}
}