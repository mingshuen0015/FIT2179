{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Staging Crisis: Late vs Early Detection",
    "subtitle": "Percentage of cases diagnosed by stage and gender",
    "anchor": "start",
    "fontSize": 16,
    "fontWeight": "bold",
    "subtitleFontSize": 12,
    "subtitleColor": "gray",
    "offset": 20
  },
  "width": 800,
  "height": 120,
  "data": {
    "values": [
      {"Gender": "Male", "Stage": "Early (Stage I & II)", "Percentage": 32.5},
      {"Gender": "Male", "Stage": "Late (Stage III & IV)", "Percentage": 67.5},
      {"Gender": "Female", "Stage": "Early (Stage I & II)", "Percentage": 37.1},
      {"Gender": "Female", "Stage": "Late (Stage III & IV)", "Percentage": 62.9}
    ]
  },
  "transform": [
    {
      "calculate": "datum.Gender + ' - ' + datum.Stage",
      "as": "Gender_Stage"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "Gender",
          "type": "nominal",
          "axis": {
            "title": null,
            "labelAngle": 0,
            "grid": false,
            "labelFontSize": 13,
            "fontWeight": "bold"
          }
        },
        "x": {
          "field": "Percentage",
          "type": "quantitative",
          "title": "Percentage of Cases (%)",
          "scale": {"domain": [0, 100]},
          "axis": {"grid": true}
        },
        "color": {
          "field": "Gender_Stage",
          "type": "nominal",
          "scale": {
            "domain": [
              "Male - Early (Stage I & II)",
              "Male - Late (Stage III & IV)",
              "Female - Early (Stage I & II)",
              "Female - Late (Stage III & IV)"
            ],
            "range": [
              "#9ecae1", 
              "#1f77b4", 
              "#fcc5c0", 
              "#dd3497"  
            ]
          },
          "legend": {
            "title": "Detection Stage",
            "orient": "right",
            "titlePadding": 10
          }
        },
        "order": {
          "field": "Stage",
          "sort": "ascending"
        },
        "tooltip": [
          {"field": "Gender", "type": "nominal"},
          {"field": "Stage", "type": "nominal"},
          {"field": "Percentage", "type": "quantitative", "title": "% of Diagnoses"}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "text": [
          "A critical majority of both men (67.5%) and women (62.9%) are diagnosed",
          "at Late Stages (III & IV), highlighting a severe national gap in early screening."
        ],
        "fontSize": 12,
        "fontStyle": "italic",
        "color": "#64748b",
        "dx": 0,
        "dy": 155
      },
      "encoding": {
        "x": {"value": 0},
        "y": {"value": 0}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "transparent"
  }
}