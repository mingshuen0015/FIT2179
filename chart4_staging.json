{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Staging Crisis: Late vs Early Detection",
    "subtitle": "Percentage of cases diagnosed by stage and gender",
    "anchor": "start",
    "fontSize": 16,
    "fontWeight": "bold",
    "subtitleFontSize": 12,
    "subtitleColor": "gray",
    "offset": 20
  },
  "width": 500,
  "height": 150,
  "data": {
    "values": [
      {"Gender": "Male", "Stage": "Early (Stage I & II)", "Percentage": 32.5},
      {"Gender": "Male", "Stage": "Late (Stage III & IV)", "Percentage": 67.5},
      {"Gender": "Female", "Stage": "Early (Stage I & II)", "Percentage": 37.1},
      {"Gender": "Female", "Stage": "Late (Stage III & IV)", "Percentage": 62.9}
    ]
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "Gender",
      "type": "nominal",
      "axis": {
        "title": null,
        "labelAngle": 0,
        "grid": false
      }
    },
    "x": {
      "field": "Percentage",
      "type": "quantitative",
      "title": "Percentage of Cases (%)",
      "scale": {"domain": [0, 100]},
      "axis": {"grid": false}
    },
    "color": {
      "field": "Stage",
      "type": "nominal",
      "scale": {
        "domain": ["Early (Stage I & II)", "Late (Stage III & IV)"],
        "range": ["#7570b3", "#d95f02"]
      },
      "legend": {
        "title": null, 
        "orient": "top",
        "offset": 5
      }
    },
    "tooltip": [
      {"field": "Gender", "type": "nominal"},
      {"field": "Stage", "type": "nominal"},
      {"field": "Percentage", "type": "quantitative", "title": "% of Diagnoses"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "background": "transparent"
  }
}